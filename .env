# Open WebUI Secret Key
# Generate a random key with: openssl rand -base64 32
# Or use: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
WEBUI_SECRET_KEY=your-secret-key-here

# MCPO API Key (for securing mcpo endpoints)
# Generate with: openssl rand -base64 32
MCPO_API_KEY=your-mcpo-api-key-here

# Chrome Token (for securing chrome endpoints)
# Generate with: openssl rand -base64 32
CHROME_TOKEN=your-chrome-token-here